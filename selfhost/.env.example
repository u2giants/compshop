# ============================================================================
# CompShop self-hosted Supabase — environment variables
# ============================================================================
# Copy this file to .env in Coolify (paste the values into Coolify's env var UI).
# NEVER commit the real .env to git.
# ============================================================================

# --- Domains ---------------------------------------------------------------
# The public hostname Kong (the API gateway) will be served on.
# This is what your app talks to for data + auth.
API_EXTERNAL_URL=https://api.comp.designflow.app
SUPABASE_PUBLIC_URL=https://api.comp.designflow.app

# Studio (admin UI) hostname. Lock this down in Coolify with basic auth or IP allowlist.
STUDIO_PUBLIC_URL=https://db.comp.designflow.app

# Site URL: where users get redirected after auth (your frontend).
SITE_URL=https://comp.designflow.app
ADDITIONAL_REDIRECT_URLS=https://comp-staging.designflow.app,http://localhost:5173

# --- Postgres --------------------------------------------------------------
POSTGRES_PASSWORD=CHANGE-ME-strong-password-32-chars-min
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=db

# --- JWT ------------------------------------------------------------------
# Generate ONE strong secret (40+ chars). Then derive ANON_KEY and SERVICE_ROLE_KEY
# from it using https://supabase.com/docs/guides/self-hosting#api-keys
# (or run scripts/generate-jwt.sh which the runbook walks you through).
JWT_SECRET=CHANGE-ME-40-char-secret
JWT_EXPIRY=3600
ANON_KEY=CHANGE-ME-jwt-signed-with-anon-role
SERVICE_ROLE_KEY=CHANGE-ME-jwt-signed-with-service_role

# --- Auth (GoTrue) --------------------------------------------------------
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_SIGNUP=false

# Google OAuth — paste the credentials from Google Cloud Console.
# Authorized redirect URI in Google must be: https://api.comp.designflow.app/auth/v1/callback
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=CHANGE-ME.apps.googleusercontent.com
GOTRUE_EXTERNAL_GOOGLE_SECRET=CHANGE-ME
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://api.comp.designflow.app/auth/v1/callback

# Authentik OIDC — "Company Account" SSO via auth.designflow.app
# GoTrue v2.x dropped the "openidconnect" provider name; we use the "keycloak"
# provider instead, routing through the oidc-compat nginx proxy that translates
# /protocol/openid-connect/* paths to Authentik's actual OIDC endpoints.
# The KEYCLOAK_URL must point at the oidc-compat proxy path (via Kong), NOT at Authentik directly.
GOTRUE_EXTERNAL_KEYCLOAK_ENABLED=true
GOTRUE_EXTERNAL_KEYCLOAK_CLIENT_ID=V5qKbQIwCZ90zXyivxS4vB36BRfC1fddJ7Aw5a6v
GOTRUE_EXTERNAL_KEYCLOAK_SECRET=6cz9TlMTqyYoFVccYq6aV1e0jNUypaaWojj7zOItlUlAAltvD7cOyndKziM7cs7PgPQOjSzLWl9CUm3CXTBLIP6jANXC4PyWzv4S7PP8wxxJdJcSe8eLwIKou0URNpI3
GOTRUE_EXTERNAL_KEYCLOAK_URL=https://api.comp.designflow.app/oidc-compat
GOTRUE_EXTERNAL_KEYCLOAK_REDIRECT_URI=https://api.comp.designflow.app/auth/v1/callback

# SMTP for invite + password-reset emails (Brevo).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=CHANGE-ME@smtp-brevo.com
SMTP_PASS=CHANGE-ME-brevo-smtp-key
SMTP_SENDER_NAME=CompShop
SMTP_ADMIN_EMAIL=CHANGE-ME@yourdomain.com

# --- Storage --------------------------------------------------------------
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800
# 50 MB per file. Bump if you upload very large videos.

# --- Studio (admin UI) credentials ----------------------------------------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE-ME-strong

# --- AI provider (used by Edge Functions) ---------------------------------
AI_PROVIDER=openrouter
AI_MODEL=google/gemini-2.5-flash
OPENROUTER_API_KEY=CHANGE-ME-rotate-the-leaked-one
OPENROUTER_HTTP_REFERER=https://comp.designflow.app
OPENROUTER_APP_TITLE=CompShop

# --- Other API keys -------------------------------------------------------
GOOGLE_MAPS_API_KEY=CHANGE-ME
BREVO_API_KEY=CHANGE-ME

# --- Lovable Cloud SOURCE (only needed during migration) ------------------
# These let the export scripts pull data FROM the existing Lovable Cloud project.
# Delete them after migration is complete.
LOVABLE_PG_HOST=aws-0-eu-central-1.pooler.supabase.com
LOVABLE_PG_PORT=6543
LOVABLE_PG_USER=postgres.aqbyrzknbhyshjzlfsyv
LOVABLE_PG_PASSWORD=CHANGE-ME-from-lovable-cloud-settings
LOVABLE_PG_DB=postgres
LOVABLE_SUPABASE_URL=https://aqbyrzknbhyshjzlfsyv.supabase.co
LOVABLE_SERVICE_ROLE_KEY=CHANGE-ME-from-lovable-cloud-settings
